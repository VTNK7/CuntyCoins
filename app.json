{
  "expo": {
    "name": "CuntyCoins",
    "slug": "cuntycoins",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0d001a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cuntycoin.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scanner les QR codes des stickers CuntyCoins"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d001a"
      },
      "package": "com.cuntycoin.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Accès à la caméra pour scanner les QR codes des stickers CuntyCoins."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bdd497f9-fe83-454b-b853-8e6e3ce97ccb"
      }
    },
    "owner": "dev-ci-cunty"
  }
}
